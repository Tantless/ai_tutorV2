{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "username",
    "delivery_type"
  ],
  "properties": {
    "username": {
      "type": "string",
      "minLength": 1
    },
    "delivery_type": {
      "type": "string",
      "enum": [
        "daily_quiz",
        "saturday_exam",
        "early_exam"
      ]
    }
  }
}
